<?xml version="1.0" encoding="UTF-8"?>

<!-- ==== mapper 기본설정 ==== -->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- ==== 루트 엘리먼트 & 네임스페이스 설정(프로젝트 전체내에서 유일해야 한다.) ==== -->

<mapper namespace="board">

	<!-- === '금쪽이' 게시판 리스트 === -->
	<resultMap type="HashMap" id="nointerList_map">
		<result property="boardName" column="boardName" javaType="String" />
		<result property="boardContent" column="boardContent" javaType="String" />
		<result property="name" column="name" javaType="String" />
	</resultMap>
	<select id="nointerList" parameterType="String" resultMap="nointerList_map">
		SELECT boardName, boardContent, name
		FROM board B JOIN users U
		ON B.fk_id = U.id
	</select>

</mapper>





